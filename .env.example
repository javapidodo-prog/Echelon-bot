# Скопируй в .env и заполни.

# Токен бота от @BotFather
BOT_TOKEN=

# Файл базы данных
DB_NAME=storage/db/echelon.db

# Режим парсера: demo для защиты/отладки, avito для live-парсинга
SCRAPER_MODE=demo
# Скрытый запуск браузера (True/False)
SCRAPER_HEADLESS=True
# Тип парсера: curl_cffi (быстрый, обходит капчу) или playwright (эмуляция браузера)
SCRAPER_TYPE=curl_cffi

# Telegram ID администратора (узнать через @userinfobot).
# Только этот пользователь имеет доступ к /validation, /set_median,
# /export_validation, /models_list, /recalculate_medians.
ADMIN_USER_ID=0

# Локальная веб-админка
ADMIN_DASHBOARD_HOST=127.0.0.1
ADMIN_DASHBOARD_PORT=8080
